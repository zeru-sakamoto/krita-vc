{
  "name": "krita-vc",
  "private": true,
  "version": "0.2.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "format": "prettier --write \"src/**/*.{ts,tsx,css}\" \"index.html\"",
    "format:check": "prettier --check \"src/**/*.{ts,tsx,css}\" \"index.html\"",
    "build": "npm run format && cargo fmt --manifest-path src-tauri/Cargo.toml && tsc && vite build",
    "preview": "vite preview",
    "screenshots": "node scripts/screenshots.mjs",
    "tauri": "tauri"
  },
  "dependencies": {
    "@phosphor-icons/react": "^2.1.10",
    "@tauri-apps/api": "^2",
    "@tauri-apps/plugin-dialog": "^2.7.1",
    "@tauri-apps/plugin-opener": "^2",
    "react": "^19.1.0",
    "react-dom": "^19.1.0"
  },
  "devDependencies": {
    "@fontsource/inter": "^5.2.8",
    "@fontsource/jetbrains-mono": "^5.2.8",
    "@tailwindcss/vite": "^4.3.1",
    "@tauri-apps/cli": "^2",
    "@types/react": "^19.1.8",
    "@types/react-dom": "^19.1.6",
    "@vitejs/plugin-react": "^4.6.0",
    "playwright": "^1.61.1",
    "prettier": "^3.8.5",
    "tailwindcss": "^4.3.1",
    "typescript": "~5.8.3",
    "vite": "^7.0.4"
  }
}
